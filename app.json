{
  "expo": {
    "name": "Doublo",
    "slug": "doublo",
    "owner": "sviara",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "doublo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sviara.doublo"
    },
    "android": {
      "package": "com.sviara.doublo",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": { "bundler": "metro", "output": "static" },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "73ad3b8b-30d5-4e1e-b9de-f52c1d23ee00"
      }
    }
  }
}
